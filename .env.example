# ====================================================================
# Cardify v3 · LLM 配置
# 也可在浏览器右上角齿轮里改，会写入 localStorage
# ====================================================================

# 调用方式：claude_relay（推荐）| claude_direct
VITE_LLM_PROVIDER="claude_relay"

# 中转地址（claude_relay 模式必填，需兼容 Anthropic Messages API）
VITE_LLM_RELAY_URL=""

# API Key（claude_direct 必填；claude_relay 可选）
VITE_LLM_API_KEY=""

# 默认模型
VITE_LLM_MODEL="claude-sonnet-4-6"
